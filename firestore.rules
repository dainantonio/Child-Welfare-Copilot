// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (Firebase Auth UID)
// Fields:
//   - uid: string (required) - User's unique ID
//   - email: string (required) - User's email address
//   - displayName: string (optional) - User's name
//   - role: string (optional) - 'admin', 'supervisor', or 'caseworker'
//   - lastLogin: timestamp (optional) - Last login time
//
// Collection: reports
// Document ID: auto-generated
// Fields:
//   - title: string (required)
//   - notes: string (optional)
//   - caseType: string (optional)
//   - state: string (optional)
//   - status: string (required) - 'draft', 'pending', 'approved', 'rejected'
//   - caseworkerId: string (required)
//   - caseworkerEmail: string (optional)
//   - supervisorId: string (optional)
//   - supervisorComments: string (optional)
//   - generatedReport: string (optional)
//   - createdAt: timestamp (required)
//   - updatedAt: timestamp (required)
//
// Collection: templates
// Document ID: auto-generated
// Fields:
//   - name: string (required)
//   - systemInstruction: string (required)
//   - createdBy: string (required)
//
// Collection: auditLogs
// Document ID: auto-generated
// Fields:
//   - userId: string (required) - UID of the caseworker
//   - userEmail: string (optional) - Email of the caseworker
//   - timestamp: timestamp (required) - When the action occurred
//   - action: string (required) - Type of action (e.g., 'generate_report')
//   - caseType: string (optional) - Type of case
//   - reportTitle: string (optional) - Title of report
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSupervisor() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supervisor';
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "dain.russell@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('role' in data) || data.role in ['admin', 'supervisor', 'caseworker']);
    }

    function isValidReport(data) {
      return data.keys().hasAll(['title', 'status', 'caseworkerId', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.status in ['draft', 'pending', 'approved', 'rejected'] &&
             data.caseworkerId is string &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidTemplate(data) {
      return data.keys().hasAll(['name', 'systemInstruction', 'createdBy']) &&
             data.name is string && data.name.size() > 0 &&
             data.systemInstruction is string && data.systemInstruction.size() > 0;
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['userId', 'timestamp', 'action']) &&
             data.userId == request.auth.uid &&
             data.timestamp == request.time &&
             data.action is string &&
             data.action.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('role' in request.resource.data) || request.resource.data.role == 'caseworker' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    // Audit Logs
    match /auditLogs/{logId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid) || isSupervisor();
      allow create: if isAuthenticated() && isValidAuditLog(request.resource.data);
      allow update, delete: if false;
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isAdmin() || isSupervisor() || (isAuthenticated() && resource.data.caseworkerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidReport(request.resource.data) && request.resource.data.caseworkerId == request.auth.uid;
      allow update: if isAuthenticated() && (
        // Caseworker can update their own draft/rejected reports
        (resource.data.caseworkerId == request.auth.uid && 
         (resource.data.status == 'draft' || resource.data.status == 'rejected') &&
         isValidReport(request.resource.data) &&
         request.resource.data.caseworkerId == resource.data.caseworkerId) ||
        // Supervisor can update status and comments
        (isSupervisor() && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'supervisorComments', 'supervisorId', 'updatedAt'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Templates
    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

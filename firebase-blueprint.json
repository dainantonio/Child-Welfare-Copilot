{
  "entities": {
    "AuditLog": {
      "title": "Audit Log",
      "description": "Records of report generation for compliance and auditing.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the caseworker." },
        "userEmail": { "type": "string", "description": "Email of the caseworker." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the report was generated." },
        "caseType": { "type": "string", "description": "Type of case processed." },
        "reportTitle": { "type": "string", "description": "Title of the report generated." },
        "action": { "type": "string", "description": "The action performed (e.g., 'generate_report')." }
      },
      "required": ["userId", "timestamp", "action"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Caseworker profile and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["caseworker", "supervisor", "admin"] },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Report": {
      "title": "Report",
      "description": "A case report draft or official document.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "notes": { "type": "string" },
        "caseType": { "type": "string" },
        "state": { "type": "string" },
        "childInfo": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "pending", "approved", "rejected"] },
        "caseworkerId": { "type": "string" },
        "caseworkerEmail": { "type": "string" },
        "supervisorId": { "type": "string" },
        "supervisorComments": { "type": "string" },
        "generatedReport": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "caseworkerId", "createdAt"]
    },
    "Template": {
      "title": "Template",
      "description": "Agency-specific prompt templates.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "systemInstruction": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "systemInstruction", "createdBy", "createdAt"]
    }
  },
  "firestore": {
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "Collection of audit logs."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Caseworker profiles."
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Case reports and drafts."
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Custom prompt templates."
    }
  }
}
